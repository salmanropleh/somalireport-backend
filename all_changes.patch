+        """Get articles posted by a specific user."""
+        if not user_id:
+            return APIResponse.error(
+                message="user_id is required in the URL path",
+                status_code=status.HTTP_400_BAD_REQUEST
+            )
+
+        try:
+            user_id = int(user_id)
